@{
    ViewData["Title"] = "C# Projects";
}

<div class="text-center mb-5">
    <h1 class="display-4">My C# Projects</h1>
    <p>Here are some of the projects I've built using C# and Unity.</p>
</div>

<div id="loading-spinner" class="text-center my-5">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <p class="mt-2">Fetching projects from GitHub...</p>
</div>

<div id="projects-container" class="project-list" style="display: none;">
    <!-- Projects will be injected here via JavaScript -->
</div>

@section Scripts {
    <script>
        const fetch_location = '/Home/GetCSharpProjectsData';
    </script>
    <script src="~/js/CreateProjectsHTML.js"></script>
}
